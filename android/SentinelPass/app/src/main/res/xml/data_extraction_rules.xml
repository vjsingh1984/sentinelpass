<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude vault database from cloud backup for security -->
        <exclude domain="file" path="sentinelpass_vault.db" />
        <exclude domain="file" path="sentinelpass_vault.db-*" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="sentinelpass_vault.db" />
        <include domain="sharedpref" path="sentinelpass.xml" />
    </device-transfer>
</data-extraction-rules>
